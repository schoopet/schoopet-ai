# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=mmontan-ml
GOOGLE_CLOUD_LOCATION=us-central1
AGENT_ENGINE_ID=2114234416376053760

# Twilio Configuration (store in Secret Manager for production)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Service Configuration
SESSION_TIMEOUT_MINUTES=10
MAX_SMS_SEGMENTS=10
AGENT_TIMEOUT_SECONDS=30

# Rate Limiting
DAILY_MESSAGE_LIMIT=1000
# Comma-separated list of phone numbers excluded from rate limiting
# RATE_LIMIT_EXCLUDED_PHONES=["+19494136310"]

# OAuth Configuration (for Google Calendar integration)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-cloud-run-url/oauth/google/callback
